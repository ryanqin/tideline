<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

  <!-- Phase 5a: in-app viewfinder capture. Camera stays optional hardware so
       camera-less devices can still install and use text / picker input. -->
  <uses-permission android:name="android.permission.CAMERA" />
  <uses-feature android:name="android.hardware.camera.any" android:required="false" />

  <!-- Phase 5b: live mic capture → on-device speech translation. Optional
       hardware for the same reason as the camera. -->
  <uses-permission android:name="android.permission.RECORD_AUDIO" />
  <uses-feature android:name="android.hardware.microphone" android:required="false" />

  <application
    android:label="Tideline"
    android:supportsRtl="true"
    android:theme="@style/Theme.Tideline">
    <activity
      android:name=".MainActivity"
      android:exported="true"
      android:theme="@style/Theme.Tideline">
      <intent-filter>
        <action android:name="android.intent.action.MAIN" />
        <category android:name="android.intent.category.LAUNCHER" />
      </intent-filter>
    </activity>
  </application>

</manifest>
