<!-- The tideline — the mark the sea leaves on the sand. An amber line where
     the water just was (wet sand below it), and a fainter coral trace above:
     the LAST tide's memory, which is the product (sediment that stays).
     The line runs past the canvas on purpose — every mask shape crops it
     like a shoreline leaving the frame. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
  <!-- wet sand below the line -->
  <path
      android:pathData="M0,75.1 C16.9,70.9 35.4,78.5 55.7,75.5 S90.7,71.3 108,75.9 L108,108 L0,108 Z"
      android:fillColor="#FFF1E4CB"/>
  <!-- the last tide's fainter trace -->
  <path
      android:pathData="M0,62.4 C23.2,59.5 40.1,65.4 63.3,62.4 S94.9,59.5 108,62.9"
      android:strokeColor="#73D9725A"
      android:strokeWidth="1.9"
      android:strokeLineCap="round"/>
  <!-- the tideline -->
  <path
      android:pathData="M0,75.1 C16.9,70.9 35.4,78.5 55.7,75.5 S90.7,71.3 108,75.9"
      android:strokeColor="#FFC2742F"
      android:strokeWidth="4.2"
      android:strokeLineCap="round"/>
</vector>
